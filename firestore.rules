rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /stats/main {
      allow read: if true;
      allow update: if 
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['visitors', 'members']) &&
        (request.resource.data.visitors == resource.data.visitors + 1 || request.resource.data.visitors == resource.data.visitors) &&
        (request.resource.data.members == resource.data.members + 1 || request.resource.data.members == resource.data.members);
      allow create: if true;
    }
  }
}
